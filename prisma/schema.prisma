generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String          @id @db.Uuid
  email                    String          @unique
  password                 String
  name                     String
  phoneNumber              String?         @map("phone_number")
  avatarUrl                String?         @map("avatar_url")
  role                     UserRole        @default(USER)
  isActive                 Boolean         @default(true) @map("is_active")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")
  lastLogin                DateTime?       @map("last_login")
  refreshTokenHash         String?         @map("refresh_token_hash")
  refreshTokenExpiry       DateTime?       @map("refresh_token_expiry")
  resetPasswordTokenHash   String?         @map("reset_password_token_hash")
  resetPasswordTokenExpiry DateTime?       @map("reset_password_token_expiry")
  approvedAt               DateTime?       @map("approved_at")
  approvedBy               String?         @map("approved_by") @db.Uuid
  rejectionReason          String?         @map("rejection_reason")
  status                   UserStatus      @default(APPROVED)
  favoritePois             FavoritePOI[]
  pageViews                PageView[]
  poiViews                 POIView[]
  pois                     POI[]
  reviews                  Review[]
  searchHistory            SearchHistory[]
  user_activity            UserActivity[]

  @@map("users")
}

model POI {
  id              String           @id @db.Uuid
  name            String           @db.VarChar(255)
  slug            String?          @db.VarChar(255)
  category        String?          @db.VarChar(50)
  latitude        Float?
  longitude       Float?
  priceMin        Int?             @map("price_min")
  priceMax        Int?             @map("price_max")
  rating          Float            @default(0)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  approvedAt      DateTime?        @map("approved_at")
  approvedBy      String?          @map("approved_by") @db.Uuid
  ownerId         String           @map("owner_id") @db.Uuid
  rejectionReason String?          @map("rejection_reason")
  status          POIStatus        @default(PENDING)
  submitCount     Int              @default(1)
  isActive        Boolean          @default(true) @map("is_active")
  favoritePois    FavoritePOI[]
  menuItems       MenuItem[]
  images          POIImage[]
  translations    POITranslation[]
  poiViews        POIView[]
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  reviews         Review[]
  tourPois        TourPOI[]

  @@index([status])
  @@index([status, isActive])
  @@map("pois")
}

model POIImage {
  id          String  @id @db.Uuid
  poiId       String  @map("poi_id") @db.Uuid
  imageUrl    String  @map("image_url")
  description String?
  poi         POI     @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@map("poi_images")
}

model MenuItem {
  id          String   @id @db.Uuid
  poiId       String   @map("poi_id") @db.Uuid
  name        String?  @db.VarChar(255)
  description String?
  price       Int?
  imageUrl    String?  @map("image_url")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  poi         POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

model POITranslation {
  id          String     @id @db.Uuid
  poiId       String     @map("poi_id") @db.Uuid
  language    String     @db.VarChar(10)
  name        String?    @db.VarChar(255)
  description String?
  audioScript String?    @map("audio_script")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  audios      POIAudio[]
  poi         POI        @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@map("poi_translations")
}

model POIAudio {
  id            String         @id @db.Uuid
  translationId String         @map("translation_id") @db.Uuid
  audioUrl      String         @map("audio_url")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  translation   POITranslation @relation(fields: [translationId], references: [id], onDelete: Cascade)

  @@map("poi_audios")
}

model FavoritePOI {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  poiId     String   @map("poi_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  poi       POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, poiId])
  @@map("favorite_pois")
}

model Review {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  poiId     String   @map("poi_id") @db.Uuid
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  poi       POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([poiId])
  @@map("reviews")
}

model PageView {
  id        String   @id @db.Uuid
  path      String
  userId    String?  @map("user_id") @db.Uuid
  sessionId String?  @map("session_id") @db.VarChar(255)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("page_views")
}

model POIView {
  id        String   @id @db.Uuid
  poiId     String   @map("poi_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  duration  Int?
  createdAt DateTime @default(now()) @map("created_at")
  poi       POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([poiId])
  @@index([createdAt])
  @@map("poi_views")
}

model SearchHistory {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  keyword   String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyword])
  @@index([createdAt])
  @@map("search_history")
}

model UserActivity {
  id         String   @id @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(50)
  targetType String?  @map("target_type") @db.VarChar(50)
  targetId   String?  @map("target_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  users      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activity")
}

/// ///////////////////////////////////////////////
/// ///////////////////////////////////////////////
model Tour {
  id              String    @id @db.Uuid
  name            String    @db.VarChar(255)
  description     String?
  imageUrl        String?   @map("image_url")
  durationMinutes Int?      @map("duration_minutes")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  isActive        Boolean   @default(true) @map("is_active")
  tourPois        TourPOI[]

  @@index([isActive])
  @@map("tours")
}

model TourPOI {
  id        String @id @db.Uuid
  tourId    String @map("tour_id") @db.Uuid
  poiId     String @map("poi_id") @db.Uuid
  stopOrder Int    @map("stop_order")
  poi       POI    @relation(fields: [poiId], references: [id], onDelete: Cascade)
  tour      Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@unique([tourId, poiId])
  @@index([tourId])
  @@index([poiId])
  @@map("tour_pois")
}

enum UserRole {
  USER
  ADMIN
  VENDOR
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum POIStatus {
  PENDING
  APPROVED
  REJECTED
}
