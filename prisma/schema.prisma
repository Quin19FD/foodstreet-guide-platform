generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////

enum UserRole {
  USER
  ADMIN
  VENDOR
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

enum POIStatus {
  PENDING
  APPROVED
  REJECTED
}

//////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////

model User {
  id        String     @id @db.Uuid
  email     String     @unique
  password  String
  name      String

  phoneNumber String?  @map("phone_number")
  avatarUrl   String?  @map("avatar_url")

  role   UserRole   @default(USER)
  status UserStatus @default(APPROVED)

  rejectionReason String? @map("rejection_reason")

  approvedBy String? @map("approved_by") @db.Uuid
  approvedAt DateTime? @map("approved_at")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  lastLogin DateTime? @map("last_login")

  refreshTokenHash   String?   @map("refresh_token_hash")
  refreshTokenExpiry DateTime? @map("refresh_token_expiry")

  resetPasswordTokenHash   String?   @map("reset_password_token_hash")
  resetPasswordTokenExpiry DateTime? @map("reset_password_token_expiry")

  pois POI[]

  favoritePois  FavoritePOI[]
  reviews       Review[]
  searchHistory SearchHistory[]

  userActivity UserActivity[]
  pageViews    PageView[]
  poiViews     POIView[]

  @@map("users")
}

//////////////////////////////////////////////////
// POI (Restaurant / Food Stall)
//////////////////////////////////////////////////

model POI {
  id      String @id @db.Uuid
  ownerId String @map("owner_id") @db.Uuid

  name     String  @db.VarChar(255)
  slug     String? @db.VarChar(255)
  category String? @db.VarChar(50)

  latitude  Float? @db.DoublePrecision
  longitude Float? @db.DoublePrecision

  priceMin Int? @map("price_min")
  priceMax Int? @map("price_max")

  rating Float @default(0)

  status POIStatus @default(PENDING)

  rejectionReason String? @map("rejection_reason")

  approvedBy String? @map("approved_by") @db.Uuid
  approvedAt DateTime? @map("approved_at")

  submitCount Int @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  images       POIImage[]
  menuItems    MenuItem[]
  translations POITranslation[]

  reviews      Review[]
  favoritePois FavoritePOI[]

  poiViews POIView[]

  @@index([status])
  @@map("pois")
}

//////////////////////////////////////////////////
// POI IMAGES
//////////////////////////////////////////////////

model POIImage {
  id       String @id @db.Uuid
  poiId    String @map("poi_id") @db.Uuid
  imageUrl String @map("image_url")

  description String?

  poi POI @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@map("poi_images")
}

//////////////////////////////////////////////////
// MENU ITEMS
//////////////////////////////////////////////////

model MenuItem {
  id    String @id @db.Uuid
  poiId String @map("poi_id") @db.Uuid

  name        String? @db.VarChar(255)
  description String?
  price       Int?

  imageUrl String? @map("image_url")

  isAvailable Boolean @default(true) @map("is_available")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  poi POI @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@map("menu_items")
}

//////////////////////////////////////////////////
// MULTI LANGUAGE
//////////////////////////////////////////////////

model POITranslation {
  id    String @id @db.Uuid
  poiId String @map("poi_id") @db.Uuid

  language String @db.VarChar(10)

  name        String? @db.VarChar(255)
  description String?

  audioScript String? @map("audio_script")

  updatedAt DateTime @updatedAt @map("updated_at")

  poi POI @relation(fields: [poiId], references: [id], onDelete: Cascade)

  audios POIAudio[]

  @@map("poi_translations")
}

//////////////////////////////////////////////////
// AUDIO GUIDE
//////////////////////////////////////////////////

model POIAudio {
  id String @id @db.Uuid

  translationId String @map("translation_id") @db.Uuid

  audioUrl String @map("audio_url")

  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  translation POITranslation @relation(fields: [translationId], references: [id], onDelete: Cascade)

  @@map("poi_audios")
}

//////////////////////////////////////////////////
// FAVORITES
//////////////////////////////////////////////////

model FavoritePOI {
  id     String @id @db.Uuid
  userId String @map("user_id") @db.Uuid
  poiId  String @map("poi_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  poi  POI  @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([userId, poiId])
  @@map("favorite_pois")
}

//////////////////////////////////////////////////
// REVIEWS
//////////////////////////////////////////////////

model Review {
  id String @id @db.Uuid

  userId String @map("user_id") @db.Uuid
  poiId  String @map("poi_id") @db.Uuid

  rating  Int
  comment String?

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  poi  POI  @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@index([poiId])
  @@map("reviews")
}

//////////////////////////////////////////////////
// ANALYTICS
//////////////////////////////////////////////////

model PageView {
  id String @id @db.Uuid

  path String

  userId String? @map("user_id") @db.Uuid

  sessionId String? @map("session_id") @db.VarChar(255)

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("page_views")
}

model POIView {
  id String @id @db.Uuid

  poiId  String  @map("poi_id") @db.Uuid
  userId String? @map("user_id") @db.Uuid

  duration Int?

  createdAt DateTime @default(now()) @map("created_at")

  poi  POI  @relation(fields: [poiId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([poiId])
  @@index([createdAt])
  @@map("poi_views")
}

//////////////////////////////////////////////////
// SEARCH HISTORY
//////////////////////////////////////////////////

model SearchHistory {
  id String @id @db.Uuid

  userId String @map("user_id") @db.Uuid
  keyword String @db.VarChar(255)

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyword])
  @@index([createdAt])
  @@map("search_history")
}

//////////////////////////////////////////////////
// USER ACTIVITY
//////////////////////////////////////////////////

model UserActivity {
  id String @id @db.Uuid

  userId String @map("user_id") @db.Uuid

  action String @db.VarChar(50)

  targetType String? @map("target_type") @db.VarChar(50)
  targetId   String? @map("target_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activity")
}