// Prisma Schema for FoodStreet Guide Platform

generator client {
  provider = "prisma-client-js";
}

datasource db {
  provider = "postgresql";
  url      = env("DATABASE_URL");
}

// ============================================================================
// User & Auth
// ============================================================================

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  phoneNumber String?
  avatarUrl   String?
  role        UserRole @default(USER)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  VENDOR
}

// ============================================================================
// District (Khu phố)
// ============================================================================

model District {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  latitude    Float
  longitude   Float
  address     String?
  qrCode      String   @unique
  imageUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  pois        POI[]

  @@map("districts")
}

// ============================================================================
// POI (Point of Interest - Gian hàng)
// ============================================================================

model POI {
  id          String      @id @default(cuid())
  districtId  String
  name        String
  slug        String
  description String
  category    POICategory
  latitude    Float
  longitude   Float
  imageUrl    String?
  audioUrl    String?
  audioScript String?     @db.Text
  priceMin    Int
  priceMax    Int
  rating      Float       @default(0)
  isOpen      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  district    District    @relation(fields: [districtId], references: [id], onDelete: Cascade)
  menuItems   MenuItem[]

  @@unique([districtId, slug])
  @@index([districtId])
  @@index([latitude, longitude])
  @@map("pois")
}

enum POICategory {
  FOOD
  DRINK
  SNACK
  DESSERT
}

// ============================================================================
// Menu Items
// ============================================================================

model MenuItem {
  id          String   @id @default(cuid())
  poiId       String
  name        String
  description String?
  price       Int
  imageUrl    String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  poi         POI      @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@index([poiId])
  @@map("menu_items")
}

// ============================================================================
// Analytics & Logs (Optional)
// ============================================================================

model PageView {
  id        String   @id @default(cuid())
  path      String
  userId    String?
  sessionId String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@map("page_views")
}

model POIView {
  id        String   @id @default(cuid())
  poiId     String
  userId    String?
  duration  Int?     // seconds
  createdAt DateTime @default(now())

  @@index([poiId])
  @@index([createdAt])
  @@map("poi_views")
}
