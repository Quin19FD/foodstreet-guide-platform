@startuml
title Activity Diagram - Tự động phát thuyết minh khi đến gần POI

start

:Ứng dụng chạy nền;
:Liên tục theo dõi vị trí User;

if (User bật định vị?) then (Có)
    :Lấy vị trí hiện tại của User;
else (Không)
    :Không thể xác định vị trí;
    stop
endif

:So sánh vị trí User với danh sách POI;

if (User đến gần POI?) then (Có)

    :Xác định POI hợp lệ gần nhất;

    if (Có nhiều POI gần nhau?) then (Có)
        :Ưu tiên POI hợp lệ nhất;
    endif

    :Hiển thị thông báo;
    note right
      "Bạn đang đến gần POI,
      bạn có muốn nghe thuyết minh không?"
    end note

    if (User đồng ý nghe?) then (Có)
        :Lấy ngôn ngữ User đã chọn;
        :Phát audio thuyết minh;
        :Hiển thị hình ảnh & menu POI;
    else (Không)
        :Không phát audio;
    endif

else (Không)
    :Tiếp tục theo dõi vị trí;
endif

stop
@enduml