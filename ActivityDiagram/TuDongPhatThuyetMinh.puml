@startuml
title Activity Diagram - Tự động phát thuyết minh khi đến gần POI

start

:Customer mở trang map;
:Ứng dụng lấy vị trí hiện tại của user;
:GET /api/customer/pois?mode=map&lat={lat}&lng={lng};

:Map tính khoảng cách đến từng POI;

if (auto prompt enabled và không có active route?) then (Có)
    if (Có POI trong vùng cảnh báo?) then (Có)
        :Chọn POI gần nhất hoặc cụm POI;
        :Hiển thị prompt "Bạn đang đến gần POI";

        if (Customer chọn "Nghe thuyết minh"?) then (Có)
            :Phát thuyết minh với audio file hoặc TTS;
        elseif (Customer chọn "Xem chi tiết"?) then (Có)
            :Chuyển tới /customer/pois/{id};
        else (Bỏ qua)
            :Tắt prompt;
        endif
    else (Không)
        :Tiếp tục theo dõi vị trí;
    endif
else (Không)
    :Không kích hoạt prompt tự động;
endif

stop

@enduml