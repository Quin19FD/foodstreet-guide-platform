{
  "permissions": {
    "allow": [
      // Bash commands
      "Bash(dir:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(npx:*)",
      "Bash(findstr:*)",
      "Bash(type:*)",
      "Bash(dir:*)",
      "Bash(rmdir:*)",
      "Bash(del:*)",
      "Bash(taskkill:*)",
      "Bash(netstat:*)",

      // Serena MCP - ALL tools for code interaction
      "mcp__plugin_serena_serena__*",

      // Playwright MCP - ALL tools for E2E testing
      "mcp__plugin_playwright_playwright__*",

      // Web Search & Context
      "mcp__web-search-prime__*",
      "mcp__web-reader__*",
      "WebSearch",
      "WebFetch"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(rm:-rf)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "instruction",
            "instruction": "⚡ WORKFLOW ENFORCED: Luôn dùng Serena MCP để đọc/viết file (KHÔNG dùng Read/Edit). Luôn dùng Playwright MCP để E2E test sau mỗi thay đổi. Quy trình: PLAN → CODE → REVIEW → OPTIMIZE → FIX BUGS → E2E TEST → LOOP."
          }
        ]
      }
    ]
  }
}